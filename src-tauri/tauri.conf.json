{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Laukey",
  "version": "0.2.0",
  "identifier": "er.local.laukey",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Laukey",
        "width": 800,
        "height": 500,
        "maximized": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Errorly",
    "category": "Utilities",
    "shortDescription": "A Local Password Manager",
    "longDescription": "Laukey is a Local Password Manager, It have dark mode support and with some features."
  }
}
